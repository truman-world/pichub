// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 定义用户模型
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String   @unique
  password  String
  role      Role     @default(USER)
  images    Image[]
  albums    Album[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}

// 定义图片模型
model Image {
  id           String   @id @default(cuid())
  filename     String   // 存储在服务器上的随机文件名
  originalName String   // 图片上传时的原始文件名
  url          String   // 图片的公共访问 URL
  size         Int
  // 关键修复: 将 userId 和 user 关系设为可选 (?)
  // 这意味着一张图片可以不属于任何用户 (例如，游客上传)
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  albumId      String?
  album        Album?   @relation(fields: [albumId], references: [id], onDelete: SetNull)

  createdAt    DateTime @default(now())
}

// 定义相册模型
model Album {
  id        String   @id @default(cuid())
  name      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  images    Image[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


// ---------------------------------------------------
// 新增模块：为您的“储存管理”宏伟蓝图奠定基础
// ---------------------------------------------------

// 定义储存驱动的类型
enum StorageProvider {
  LOCAL
  S3
  ALIYUN_OSS
  TENCENT_COS
  FTP
  SFTP
  WEBDAV
  // 未来可以继续扩展...
}

// 定义储存策略模型
model Storage {
  id        String          @id @default(cuid())
  name      String          // 例如："默认本地存储", "阿里云华东区存储"
  provider  StorageProvider // 驱动类型
  config    Json            // 存储该驱动所需的配置信息 (如 AccessKey, SecretKey, Bucket 等)
  isDefault Boolean         @default(false) // 是否为游客/新用户的默认存储
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}
